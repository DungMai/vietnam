# Supabase (Postgres + pgvector + Auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# LLM providers (see 03-DECISIONS/0002-rag-and-persona-architecture.md §3-tier routing)
GOOGLE_GENERATIVE_AI_API_KEY=
ANTHROPIC_API_KEY=

# Email — Resend (anonymous magic-link gate; see 02-SPECS/anonymous-rate-limit-and-email-gate.md)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@vietnam.app

# R2 — Asset storage for fixer-sourced photography (see 02-SPECS/content-corpora-and-fixer.md)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vietnam-assets

# Share-card HMAC signing (see 02-SPECS/tiktok-share-cards.md §tamper-evident)
SHARE_CARD_HMAC_SECRET=

# Observability
SENTRY_DSN=

# Cost-monitoring alerts (see 03-DECISIONS/0003-llm-cost-monitoring.md)
FOUNDER_ALERT_EMAIL=
