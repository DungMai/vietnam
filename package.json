{
  "name": "vietnam-app",
  "version": "0.0.1",
  "private": true,
  "description": "vietnam — 10 AI agents, one per Tier-1 Vietnamese province. Bilingual EN/VI. Anti-scam, fixer-verified.",
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "supabase db push",
    "db:reset": "supabase db reset",
    "db:seed": "psql $DATABASE_URL -f supabase/seed.sql",
    "rag:ingest": "tsx scripts/ingest-corpus.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.2.0",
    "@ai-sdk/anthropic": "^1.2.0",
    "ai": "^4.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "@supabase/ssr": "^0.5.0",
    "@vercel/og": "^0.6.0",
    "next": "15.1.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "resend": "^4.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "15.1.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
